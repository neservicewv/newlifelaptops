# Database
DATABASE_URL="file:./dev.db"

# eBay Developer App Credentials
# Get these from: https://developer.ebay.com/my/keys
EBAY_CLIENT_ID="your-ebay-client-id"
EBAY_CLIENT_SECRET="your-ebay-client-secret"

# eBay OAuth Redirect URI
# Must match exactly what you register in eBay Developer console
# For local dev: http://localhost:3000/api/ebay/callback
# For production: https://yourdomain.com/api/ebay/callback
EBAY_REDIRECT_URI="http://localhost:3000/api/ebay/callback"

# eBay Environment: "sandbox" or "production"
EBAY_ENV="sandbox"

# App secret for session signing
NEXTAUTH_SECRET="change-this-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"
